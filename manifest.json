{
  "manifest_version": 3,
  "name": "言念起始页",
  "version": "2.0.0",
  "description": "追求极致纯净与效率的双模浏览器主页，内置Win95风格书签收藏管理。鼠标右键呼出管理器，按Ctrl+/切换模式。",
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "icons": {
    "16": "icon.png",
    "32": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "permissions": [
    "storage",
    "activeTab"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "收藏当前网页",
    "default_icon": "icon.png"
  }
}